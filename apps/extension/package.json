{
  "name": "@replyrocket/extension",
  "displayName": "ReplyRocket",
  "version": "0.1.0",
  "private": true,
  "description": "AI replies in your voice — for Gmail, Outlook, LinkedIn, Slack, WhatsApp, and X.",
  "author": "ReplyRocket",
  "scripts": {
    "dev": "plasmo dev",
    "build": "plasmo build",
    "package": "plasmo package",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@plasmohq/messaging": "^0.6.2",
    "@plasmohq/storage": "^1.13.0",
    "@replyrocket/shared": "workspace:*",
    "plasmo": "0.89.4",
    "react": "18.3.1",
    "react-dom": "18.3.1"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.281",
    "@types/node": "^22.9.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "typescript": "^5.6.3"
  },
  "manifest": {
    "name": "ReplyRocket — AI replies",
    "host_permissions": [
      "https://mail.google.com/*",
      "https://outlook.live.com/*",
      "https://outlook.office.com/*",
      "https://outlook.office365.com/*",
      "https://www.linkedin.com/*",
      "https://app.slack.com/*",
      "https://web.whatsapp.com/*",
      "https://x.com/*",
      "https://twitter.com/*",
      "https://reply-rocket-web.vercel.app/*",
      "http://localhost:3000/*"
    ],
    "permissions": ["storage", "activeTab", "scripting"],
    "externally_connectable": {
      "matches": [
        "https://reply-rocket-web.vercel.app/*",
        "http://localhost:3000/*"
      ]
    }
  }
}
